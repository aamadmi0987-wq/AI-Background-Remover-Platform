APP_NAME="AI Background Remover Platform"
ENV=development
API_V1_PREFIX=/api/v1

POSTGRES_DSN=postgresql+psycopg2://app:app@postgres:5432/aibg
REDIS_URL=redis://redis:6379/0

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=images
MINIO_SECURE=false

JWT_SECRET_KEY=please-change-me
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=60

CAPTCHA_SECRET=dev-bypass
BLOCK_TEMP_DOMAINS=mailinator.com,10minutemail.com,guerrillamail.com
VERIFICATION_BASE_URL=http://localhost/api/v1/auth/verify-email
